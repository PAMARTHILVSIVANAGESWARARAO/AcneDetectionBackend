# Server
PORT=5000
NODE_ENV=production

# Security
JWT_SECRET=replace_with_a_random_32_plus_char_secret
TRUST_PROXY=1

# Database
MONGO_URI=mongodb://localhost:27017/acnedb

# External Services
ML_API_URL=https://your-ml-service.example.com/predict
GROQ_API_KEY=replace_with_groq_api_key
GROQ_MODEL=llama-3.1-8b-instant

# CORS
# Comma-separated list. Wildcards are supported, e.g. https://*.onrender.com
ALLOWED_ORIGINS=https://your-frontend.example.com,http://localhost:5173
# Development only: set to true to allow all origins
ALLOW_ALL_ORIGINS=false

# Rate Limiting
AUTH_RATE_LIMIT_MAX=50
GENERAL_RATE_LIMIT_MAX=100

# SMTP configuration for Nodemailer
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASS=replace_with_app_password
SMTP_SECURE=false
SMTP_FROM=AcneAI <no-reply@example.com>
SMTP_DOMAIN=gmail.com
